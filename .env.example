VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Disabled by default. Set to true only if you explicitly want static-token mode.
VITE_ENABLE_STATIC_ADMIN_TOKEN=false
# Only used when VITE_ENABLE_STATIC_ADMIN_TOKEN=true
VITE_ADMIN_BEARER_TOKEN=your-admin-jwt
# Optional if you use custom edge-functions domain:
# VITE_SUPABASE_FUNCTIONS_URL=https://your-project-ref.functions.supabase.co
# Optional: cuenta de Gmail a forzar al abrir "Abrir correo" (usa authuser en Gmail Web).
# Si no se define, se abre el cliente por defecto mediante mailto:
# VITE_ONBOARDING_EMAIL_AUTHUSER=mibars@onusexpress.com
# DEV ONLY: autologin admin sin pasar por la UI de login (requiere credenciales validas).
# VITE_DEV_AUTO_LOGIN_ADMIN=true
# VITE_DEV_AUTO_LOGIN_ADMIN_EMAIL=admin@empresa.com
# VITE_DEV_AUTO_LOGIN_ADMIN_PASSWORD=tu-password-admin
# Optional: URL base del portal worker para generar enlace de login autocompletado en WhatsApp.
# Si no se define, se usa `${window.location.origin}/worker`.
# VITE_WORKER_PORTAL_URL=https://worker.onusexpress.com

# Version vigente de condiciones de uso del portal worker (forzar re-aceptacion al cambiarla)
VITE_WORKER_TERMS_VERSION=v1.1-2026-03-05

# Opcional: enlaces publicos a documentos para mostrar en la modal de aceptacion
# VITE_WORKER_TERMS_DOC_URL=https://example.com/PROTOCOLO_INTERNO_FICHAJE_ONUS.pdf
# VITE_WORKER_PRIVACY_DOC_URL=https://example.com/CLAUSULA_INFORMATIVA_RGPD_FICHAJE.pdf

# Opcional: etiqueta de version de app para trazabilidad en aceptacion
# VITE_APP_VERSION=worker-portal-2026.03.05
